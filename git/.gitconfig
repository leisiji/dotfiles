[user]
	email = 2265215145@qq.com
	name = leisiji
[core]
	editor = nvim --cmd 'let g:unception_block_while_host_edits=1'
	excludesfile = ~/.gitignore_global
    pager = DELTA_FEATURES=$([[ ${COLUMNS:-$(tput cols)} -gt 160 ]] && echo "+side-by-side" || echo "+") delta

[color]
	ui = true

[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    features = colibri
# [merge]
#     conflictStyle = zdiff3
# [pager]
# 	show = git-split-diffs --color | less -+LFX
# 	diff = git-split-diffs --color | less -+LFX
[alias]
	rg = !rg $(git rev-parse --show-toplevel) --column --smart-case -e
	cma = commit --amend
	df = diff .
	dfc = diff --cached
	dfs = diff --cached --stat
[init]
	defaultBranch = main
[http]
	sslverify = false


[delta "colibri"]
    # author: https://github.com/pablospe
    # Based on woolly-mammoth: https://github.com/Kr1ss-XD.
    commit-decoration-style = 130 box
    dark = true
    file-decoration-style = "#606018" overline
    file-added-label = [●]
    file-copied-label = [C]
    file-modified-label = [+]
    file-removed-label = [⛌]
    file-renamed-label = [→]
    file-style = 232 bold 184
    hunk-header-style = syntax bold italic 237
    line-numbers = true
    line-numbers-left-format = "{nm:>1}┊"
    line-numbers-left-style = white
    line-numbers-minus-style = white
    line-numbers-plus-style = white
    line-numbers-right-format = " {np:>1}┊"
    line-numbers-right-style = white
    line-numbers-zero-style = "#545474" italic
    minus-emph-style = normal "#80002a"
    minus-style = normal "#5e0000"
    plus-emph-style = syntax bold "#007e5e"
    plus-style = syntax "#003500"
    syntax-theme = OneHalfDark
    whitespace-error-style = "#80002a" reverse
    zero-style = syntax
    blame-format = "{author:<18} ({commit:>7}) ┊{timestamp:^16}┊ "
